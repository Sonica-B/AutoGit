{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2022",
    "outDir": "out",
    "lib": ["es2022"],
    "sourceMap": false,
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "types": ["node", "vscode"]
  },
  "include": [
    "extension.js",
    "lib/**/*.js"
  ],
  "exclude": [
    "node_modules",
    ".vscode-test",
    "out"
  ]
}
