{
  "name": "auto-git-copilot",
  "displayName": "AutoGit-AI",
  "description": "Automatically stage, commit, and push changes with AI-generated commit messages using GitHub Copilot",
  "version": "1.1.0",
  "publisher": "ShreyaBoyane",
  "license": "Apache-2.0",
  "icon": "icon.png",
  "author": {
    "name": "Shreya Boyane",
    "email": "shreya.boyane@gmail.com"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "SCM Providers"
  ],
  "keywords": [
    "git",
    "auto-commit",
    "copilot",
    "ai",
    "automation",
    "github",
    "commit-messages",
    "productivity"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Sonica-B/AutoGit.git"
  },
  "bugs": {
    "url": "https://github.com/Sonica-B/AutoGit/issues"
  },
  "homepage": "https://github.com/Sonica-B/AutoGit#readme",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "galleryBanner": {
    "color": "#2D2D30",
    "theme": "dark"
  },
  "contributes": {
    "commands": [
      {
        "command": "autoGitCopilot.toggle",
        "title": "Toggle Auto Git",
        "category": "Auto Git",
        "icon": "$(git-branch)"
      },
      {
        "command": "autoGitCopilot.enable",
        "title": "Enable Auto Git",
        "category": "Auto Git",
        "icon": "$(check)"
      },
      {
        "command": "autoGitCopilot.disable",
        "title": "Disable Auto Git",
        "category": "Auto Git",
        "icon": "$(circle-slash)"
      },
      {
        "command": "autoGitCopilot.commitNow",
        "title": "Commit Changes Now",
        "category": "Auto Git",
        "icon": "$(git-commit)"
      },
      {
        "command": "autoGitCopilot.showLogs",
        "title": "Show Logs",
        "category": "Auto Git",
        "icon": "$(output)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "autoGitCopilot.toggle",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "autoGitCopilot.enable",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "autoGitCopilot.disable",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "autoGitCopilot.commitNow",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "autoGitCopilot.showLogs"
        }
      ]
    },
    "configuration": {
      "title": "Auto Git with Copilot",
      "properties": {
        "autoGitCopilot.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable automatic git operations when files change",
          "order": 1
        },
        "autoGitCopilot.delayMs": {
          "type": "number",
          "default": 3000,
          "minimum": 1000,
          "maximum": 30000,
          "description": "Delay in milliseconds before triggering git operations after a file change (1000-30000ms)",
          "order": 2
        },
        "autoGitCopilot.autoPush": {
          "type": "boolean",
          "default": true,
          "description": "Push to the remote after each automatic commit. Disable to commit locally only.",
          "order": 3
        },
        "autoGitCopilot.includeUntracked": {
          "type": "boolean",
          "default": true,
          "description": "Include untracked files in automatic commits",
          "order": 4
        },
        "autoGitCopilot.useAI": {
          "type": "boolean",
          "default": true,
          "description": "Generate commit messages with the Copilot language model. When disabled (or unavailable), a descriptive fallback message is used.",
          "order": 5
        },
        "autoGitCopilot.maxCommitMessageLength": {
          "type": "number",
          "default": 72,
          "minimum": 20,
          "maximum": 200,
          "description": "Maximum length for commit messages (20-200 characters)",
          "order": 6
        },
        "autoGitCopilot.protectedBranches": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Branch names on which auto-commit is skipped (e.g. [\"main\", \"master\"])",
          "order": 7
        },
        "autoGitCopilot.notificationLevel": {
          "type": "string",
          "enum": [
            "all",
            "errors",
            "none"
          ],
          "enumDescriptions": [
            "Show all notifications, including successful commits",
            "Only show warnings and errors",
            "Never show popup notifications (status bar and logs only)"
          ],
          "default": "errors",
          "description": "Which popup notifications to show. Full details are always written to the Auto Git output channel.",
          "order": 8
        },
        "autoGitCopilot.excludePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "node_modules/**",
            ".git/**",
            "*.log",
            ".env*",
            "dist/**",
            "build/**",
            "out/**",
            "*.tmp",
            "*.temp",
            ".DS_Store",
            "Thumbs.db",
            "*.vsix",
            ".vscode-test/**",
            "coverage/**",
            "*.lock",
            "package-lock.json"
          ],
          "description": "File patterns to exclude from auto-commit (glob patterns: * matches within a segment, ** across segments; patterns without / match at any depth)",
          "order": 9
        }
      }
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "eslint": "^9.0.0",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check": "node --check extension.js && node --check lib/patterns.js && node --check lib/commitMessage.js && node --check lib/gitService.js",
    "test": "node --test",
    "pretest": "npm run check",
    "package": "npx @vscode/vsce package"
  }
}
